# Admin dashboard password (required for /admin)
# Set one of:
#   JOLT_ADMIN_PASSWORD=your-secret-password
#   NUXT_JOLTHOST_ADMIN_PASSWORD=your-secret-password

# Optional: secret for signing admin session cookie (defaults to JOLT_VIEW_SECRET)
# JOLT_ADMIN_SECRET=your-admin-secret

# Optional: secret for signing web session cookie (allows uploads via web form)
# JOLT_WEB_SECRET=your-web-secret

# Optional: max upload size in bytes (default 25MB). Example: 52428800 for 50MB.
# NUXT_JOLTHOST_UPLOAD_MAX_BYTES=26214400 (25MB)
