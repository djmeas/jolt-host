{
  "name": "jolt-host",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "deploy": "nuxt build && wrangler pages deploy",
    "db:migrate:local": "wrangler d1 execute jolt-host-db --local --file=migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute jolt-host-db --remote --file=migrations/0001_init.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run server/",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:fixtures": "node scripts/build-test-fixtures.mjs"
  },
  "dependencies": {
    "fflate": "^0.8.2",
    "mime-types": "^2.1.35",
    "nuxt": "^3.14.1590"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "@nuxt/devtools": "latest",
    "@nuxt/test-utils": "^4.0.0",
    "@vue/test-utils": "^2.4.6",
    "archiver": "^7.0.1",
    "happy-dom": "^20.8.3",
    "nitro-test-utils": "^0.11.2",
    "vitest": "^4.0.18",
    "wrangler": "^4.72.0"
  },
  "engines": {
    "node": ">=18"
  }
}
